import os

# To run locally:
# snakemake --snakefile Snakefile_simulate_test --rerun-triggers mtime --keep-going --cores 12 --use-singularity --singularity-prefix ~/.singularity --singularity-args "--home ~"
# To run on maestro:
# source ~/.bashrc && conda activate snakemake && module load apptainer && cd /pasteur/helix/projets/mPath/anna/projects/bdext/sim_bdeiss
# snakemake --snakefile Snakefile_simulate_test --rerun-triggers mtime --config model=BD --keep-going --cores 1 --use-singularity --singularity-prefix $HOME/.singularity --singularity-args "-B /pasteur" --cluster "sbatch -c {threads} -o {folder}/logs/{params.name}.log -e {folder}/logs/{params.name}.log --mem={params.mem} -p common,dedicated --qos=fast  -J {params.name}" --jobs 500


localrules: all


folder = os.path.abspath(config.get("folder", '.'))
num = int(config.get("num", 1000))
REPETITIONS = list(range(num))
os.makedirs('logs', exist_ok=True)

sim_folder = os.path.join(folder, config.get("sf", 'test'))
MODELS = ['BD', 'BDCT', 'BDEI', 'BDEICT', 'BDSS', 'BDSSCT', 'BDEISS', 'BDEISSCT']
SIZES=['2000_5000']

snakemake_settings = "  --rerun-triggers mtime --keep-going --cores 1 --jobs 500 --rerun-incomplete --cluster  \"sbatch -c {threads} -o {folder}/logs/{params.name}.log -e {folder}/logs/{params.name}.log --mem={params.mem} -p common,dedicated --qos=fast  -J {params.name}\"  --use-singularity --singularity-prefix \"$HOME/.singularity\" --singularity-args \"-B /pasteur\" " \
    if "pasteur" in folder else " --rerun-triggers mtime --keep-going --cores 12 --use-singularity --singularity-prefix ~/.singularity --singularity-args \"--home ~\""


rule all:
    input:
        expand(os.path.join(sim_folder, '{size}', '{model}', 'trees.csv.xz'), model=MODELS, size=SIZES),
    shell:
        """
        snakemake --snakefile Snakefile_estimate --config num={num} {snakemake_settings} --unlock
        snakemake --snakefile Snakefile_estimate --config num={num} {snakemake_settings}
        """


rule simulate_bdeissct_trees:
    '''
    Simulate a BDEISSCT tree.
    '''
    output:
        log=os.path.join(sim_folder, '{mint}_{maxt}', 'BDEISSCT', 'tree.{i}.log'),
        nwk=os.path.join(sim_folder, '{mint}_{maxt}', 'BDEISSCT', 'tree.{i}.nwk'),
    params:
        mem=2000,
        name='{i}.BDEISSCT',
        qos='fast'
    threads: 1
    singularity: "docker://evolbioinfo/treesimulator:v0.2.24"
    shell:
        """
        python3 py/generate_tree_sets.py --log {output.log} --nwk {output.nwk} \
        --min_tips {wildcards.mint} --max_tips {wildcards.maxt} \
        --n 1 \
        --min_R 1 \
        --max_R 10  \
        --min_d 0.5  \
        --max_d 12  \
        --min_rho 0.05  \
        --max_rho 0.5  \
        --min_ups 0.05  \
        --max_ups 0.5  \
        --min_xc 20  \
        --max_xc 100  \
        --min_kappa 1 \
        --max_kappa 1 \
        --min_fe 0.1  \
        --max_fe 0.9  \
        --min_fss 0.05  \
        --max_fss 0.5  \
        --min_xss 5  \
        --max_xss 20
        """

