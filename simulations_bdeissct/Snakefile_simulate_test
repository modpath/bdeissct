localrules: all


folder = os.path.abspath(config.get("folder", '.'))
num = int(config.get("num", 1000))
REPETITIONS = list(range(num))
os.makedirs('logs', exist_ok=True)

sim_folder = os.path.join(folder, config.get("sf", 'test'))
MODELS = ['BD', 'BDCT', 'BDEI', 'BDEICT', 'BDSS', 'BDSSCT', 'BDEISS', 'BDEISSCT']
SIZES=['200_500']

snakemake_settings = "  --rerun-triggers mtime --keep-going --cores 1 --jobs 8000 --rerun-incomplete --cluster  \"sbatch -c {threads} -o {folder}/logs/{params.name}.log -e {folder}/logs/{params.name}.log --mem={params.mem} -p common,dedicated --qos=fast  -J {params.name}\"  --use-singularity --singularity-prefix \"$HOME/.singularity\" --singularity-args \"-B /pasteur\" " \
    if "pasteur" in folder else " --rerun-triggers mtime --keep-going --cores 12 --use-singularity --singularity-prefix ~/.singularity --singularity-args \"--home ~\""


rule all:
    input:
        expand(os.path.join(sim_folder, '{size}', '{model}', 'trees.csv.xz'), model=MODELS, size=SIZES),
    shell:
        """
        snakemake --snakefile Snakefile_simulate_train {snakemake_settings} --unlock
        snakemake --snakefile Snakefile_simulate_train {snakemake_settings}
        """


rule simulate_tree:
    '''
    Simulate a tree under a given model.
    '''
    output:
        log=os.path.join(sim_folder, '{mint}_{maxt}', '{model}', 'tree.{i}.log'),
        nwk=os.path.join(sim_folder, '{mint}_{maxt}', '{model,[BDEISCT]+}', 'tree.{i}.nwk'),
    params:
        mem=2000,
        name='sim.{model}.test',
        qos='fast'
    threads: 1
    singularity: "docker://evolbioinfo/bdext:v0.1.67"
    shell:
        """
        python3 py/generate_tree_sets.py --log {output.log} --nwk {output.nwk} \
        --min_tips {wildcards.mint} --max_tips {wildcards.maxt} \
        --n 1 \
        --min_R 1 \
        --max_R 10  \
        --min_d 1  \
        --max_d 31  \
        --min_d_inc 0.01  \
        --min_rho 0.05  \
        --max_rho 0.75  \
        --min_ups 0.05  \
        --max_ups 0.75  \
        --min_xc 10  \
        --max_xc 100  \
        --min_kappa 1000 \
        --max_kappa 1000 \
        --min_fss 0.05  \
        --max_fss 0.5  \
        --min_xss 5  \
        --max_xss 25 \
        --model {wildcards.model} 
        """

rule encode_test:
    '''
    Encodes simulated test set as sumstats.
    '''
    input:
        nwk = expand(os.path.join(sim_folder, '{{size}}', '{{model}}', 'tree.{i}.nwk'), i=range(num)),
        log = expand(os.path.join(sim_folder, '{{size}}', '{{model}}', 'tree.{i}.log'), i=range(num)),
    output:
        stats = os.path.join(sim_folder, '{size,[0-9]+_[0-9]+}', '{model,[BDEISCT]+}', 'trees.csv.xz')
    params:
        mem=2000,
        name='enc.{model}.test',
        qos='fast'
    threads: 1
    singularity: "docker://evolbioinfo/bdext:v0.1.67"
    shell:
        """
        bdeissct_encode --nwks {input.nwk} --logs {input.log} --out {output.stats}
        """