rule encode_test:
    '''
    Encodes simulated test set as sumstats.
    '''
    input:
        nwk = expand(os.path.join(sim_folder, '{{size}}', '{{model}}', 'tree.{i}.nwk'), i=range(num)),
    output:
        stats = os.path.join(sim_folder, '{size,[0-9]+_[0-9]+}', '{model,[BDEISCT0-9]+}', 'trees.csv.xz')
    params:
        mem=2000,
        name='enc.{model}.test',
        qos='fast',
        nwk=os.path.join(sim_folder, '{size}', '{model}', 'tree.*.nwk'),
    threads: 1
    singularity: "docker://evolbioinfo/bdext:v0.1.49"
    shell:
        """
        bdeissct_encode --patterns {params.nwk} --out {output.stats}
        """