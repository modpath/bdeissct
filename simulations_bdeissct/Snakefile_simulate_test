localrules: all


folder = os.path.abspath(config.get("folder", '.'))
num = int(config.get("num", 1000))
REPETITIONS = list(range(num))
os.makedirs('logs', exist_ok=True)

sf = config.get("sf", 'test')

MODELS = [f'BD{ei}{ss}{ct}' for ei in ['', 'EI'] for ss in ['', 'SS'] for ct in ['', 'CT']]
mint = int(config.get("mint", 200))
maxt = int(config.get("maxt", 500))
sim_folder = os.path.join(folder, sf, f'{mint}_{maxt}')

snakemake_settings = "  --rerun-triggers mtime --keep-going --cores 1 --jobs 8000 --rerun-incomplete --cluster  \"sbatch -c {threads} -o {folder}/logs/{params.name}.log -e {folder}/logs/{params.name}.log --mem={params.mem} -p common,dedicated --qos=fast  -J {params.name}\"  --use-singularity --singularity-prefix \"$HOME/.singularity\" --singularity-args \"-B /pasteur\" " \
    if "pasteur" in folder else " --rerun-triggers mtime --keep-going --cores 12 --use-singularity --singularity-prefix ~/.singularity --singularity-args \"--home ~\""


rule all:
    input:
        expand(os.path.join(sim_folder, '{model}','tree.{i}.nwk'),i=range(1000), model=MODELS),
    shell:
        """
        snakemake --snakefile Snakefile_encode_test --config mint={mint} maxt={maxt} {snakemake_settings} --unlock
        snakemake --snakefile Snakefile_encode_test --config mint={mint} maxt={maxt} {snakemake_settings}
        """


rule simulate_tree:
    '''
    Simulate a tree under a given model.
    '''
    output:
        log=os.path.join(sim_folder, '{model}', 'tree.{i}.log'),
        nwk=os.path.join(sim_folder, '{model,[BDEISCT]+}', 'tree.{i}.nwk'),
    params:
        mem=2000,
        name='sim.{model}.test',
        qos='fast'
    threads: 1
    singularity: "docker://evolbioinfo/bdext:v0.1.98"
    shell:
        """        
        bdeissct_simulate --log {output.log} --nwk {output.nwk} \
        --min_tips {mint} --max_tips {maxt} \
        --n 1 \
        --min_R 1 \
        --max_R 10  \
        --min_d 1  \
        --max_d 31  \
        --min_d_inc 0.01  \
        --min_rho 0.05  \
        --max_rho 0.75  \
        --min_ups 0.05  \
        --max_ups 0.75  \
        --min_xc 10  \
        --max_xc 100  \
        --min_kappa 1000 \
        --max_kappa 1000 \
        --min_fss 0.05  \
        --max_fss 0.5  \
        --min_xss 5  \
        --max_xss 25 \
        --model_name {wildcards.model} \
        --record_observed
        """
