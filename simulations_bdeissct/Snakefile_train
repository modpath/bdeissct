        train_trees_BDEISSCT = expand(os.path.join(sim_folder, 'BDEISSCT', '{k}', 'trees.csv.xz'), k=range(N_TRAIN)),
        val_trees_BD = expand(os.path.join(sim_folder, 'BD', '{k}', 'trees.csv.xz'), k=range(N_TRAIN,N_TOTAL)),
        val_trees_BDCT = expand(os.path.join(sim_folder, 'BDCT', '{k}', 'trees.csv.xz'), k=range(N_TRAIN,N_TOTAL)),
        val_trees_BDEI = expand(os.path.join(sim_folder, 'BDEI', '{k}', 'trees.csv.xz'), k=range(N_TRAIN,N_TOTAL)),
        val_trees_BDEICT = expand(os.path.join(sim_folder, 'BDEICT', '{k}', 'trees.csv.xz'), k=range(N_TRAIN,N_TOTAL)),
        val_trees_BDSS = expand(os.path.join(sim_folder, 'BDSS', '{k}', 'trees.csv.xz'), k=range(N_TRAIN,N_TOTAL)),
        val_trees_BDSSCT = expand(os.path.join(sim_folder, 'BDSSCT', '{k}', 'trees.csv.xz'), k=range(N_TRAIN,N_TOTAL)),
        val_trees_BDEISS = expand(os.path.join(sim_folder, 'BDEISS', '{k}', 'trees.csv.xz'), k=range(N_TRAIN,N_TOTAL)),
        val_trees_BDEISSCT = expand(os.path.join(sim_folder, 'BDEISSCT', '{k}', 'trees.csv.xz'), k=range(N_TRAIN,N_TOTAL)),
    output:
        model = os.path.join(model_folder, 'MF', 'ffnn.keras')
    params:
        mem=2000,
        name='train_mf',
        qos='fast',
        path = os.path.join(sim_folder, 'MF'),
        train_labels =(['BD'] * N_TRAIN) + (['BDCT'] * N_TRAIN) + (['BDSS'] * N_TRAIN) + (['BDSSCT'] * N_TRAIN) \
                      + (['BDEI'] * N_TRAIN) + (['BDEICT'] * N_TRAIN) + (['BDEISS'] * N_TRAIN) + (['BDEISSCT'] * N_TRAIN),
        val_labels =(['BD'] * N_VAL) + (['BDCT'] * N_VAL) + (['BDSS'] * N_VAL) + (['BDSSCT'] * N_VAL) \
                    + (['BDEI'] * N_VAL) + (['BDEICT'] * N_VAL) + (['BDEISS'] * N_VAL) + (['BDEISSCT'] * N_VAL)
    threads: 1
    singularity: "docker://evolbioinfo/bdext:v0.1.35"
    shell:
        """        
        bdeissct_train_model_finder \
        --train_data {input.train_trees_BD} {input.train_trees_BDCT} \
        {input.train_trees_BDSS} {input.train_trees_BDSSCT} \
        {input.train_trees_BDEI} {input.train_trees_BDEICT} \
        {input.train_trees_BDEISS} {input.train_trees_BDEISSCT} \
        --train_labels {params.train_labels} \
         --val_data {input.val_trees_BD} {input.val_trees_BDCT} \
        {input.val_trees_BDSS} {input.val_trees_BDSSCT} \
        {input.val_trees_BDEI} {input.val_trees_BDEICT} \
        {input.val_trees_BDEISS} {input.val_trees_BDEISSCT} \
        --val_labels {params.val_labels} \
         --model_path {params.path}
        """