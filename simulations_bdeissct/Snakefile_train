folder = os.path.abspath(config.get("folder", '.'))

os.makedirs('logs', exist_ok=True)

train = config.get("train", "covid_train")

mint = int(config.get("mint", 200))
maxt = int(config.get("maxt", 500))
SIZE = '{}_{}'.format(mint, maxt)

MODELS = ['BD', 'BDCT', 'BDEI', 'BDEICT', 'BDSS', 'BDSSCT', 'BDEISS', 'BDEISSCT']


snakemake_settings = "  --rerun-triggers mtime --keep-going --cores 1 --jobs 500 --rerun-incomplete --cluster  \"sbatch -c {threads} -o {folder}/logs/{params.name}.log -e {folder}/logs/{params.name}.log --mem={params.mem} -p common,dedicated --qos=fast  -J {params.name}\"  --use-singularity --singularity-prefix \"$HOME/.singularity\" --singularity-args \"-B /pasteur\" " \
    if "pasteur" in folder else " --rerun-triggers mtime --keep-going --cores 1"


rule all:
    input:
        expand(os.path.join(folder, 'pure_models_{x}', SIZE, '{model}.keras'), model=MODELS, x=[8]),
        expand(os.path.join(folder, 'pure_models_{x}', SIZE, '{model}.keras'), model=MODELS, x=[1, 2, 4, 8]),
        expand(os.path.join(folder, 'mixed_models_2', SIZE, '{model}.keras'), model=['BDCT', 'BDEI', 'BDSS']),
        expand(os.path.join(folder, 'mixed_models_4', SIZE, '{model}.keras'), model=[m for m in MODELS if m not in {'BD', 'BDEISSCT'}]),
        expand(os.path.join(folder, 'mixed_models_8', SIZE, '{model}.keras'), model=[m for m in MODELS if 'BD' != m]),
    shell:
        """
        snakemake --snakefile Snakefile_train_per_target --config mint={mint} maxt={maxt} {snakemake_settings} --unlock
        snakemake --snakefile Snakefile_train_per_target --config mint={mint} maxt={maxt} {snakemake_settings}
        """

