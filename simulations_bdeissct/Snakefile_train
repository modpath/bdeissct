import os


# To run locally:
# snakemake --snakefile Snakefile_train --keep-going --cores 1 --rerun-triggers mtime
# snakemake --snakefile Snakefile_train --keep-going --cores 1 --use-singularity --singularity-prefix ~/.singularity --singularity-args "--home ~"


localrules: all


folder = os.path.abspath(config.get("folder", '.'))

N_TRAIN = 120
N_TRAIN_OTHER = 120
N_TOTAL = 128
N_VAL = N_TOTAL - N_TRAIN
N_VAL_OTHER = 8

os.makedirs('logs', exist_ok=True)

sim_folder = os.path.join(folder, config.get("sf", 'training'), '500_1000')
model_folder = os.path.join(folder, 'models', '500_1000')
model = config.get('model', None)
# MODELS = [model] if model else ['BD', 'BDCT', 'BDEI', 'BDEICT', 'BDSS', 'BDSSCT', 'BDEISS', 'BDEISSCT', 'MF']
MODELS = [model] if model is not None else ['BD', 'BDCT', 'BDEI', 'BDEICT', 'BDSS', 'BDSSCT', 'BDEISS', 'BDEISSCT']


snakemake_settings = "  --rerun-triggers mtime --keep-going --cores 1 --jobs 500 --rerun-incomplete --cluster  \"sbatch -c {threads} -o {folder}/logs/{params.name}.log -e {folder}/logs/{params.name}.log --mem {params.mem} -p common --qos=normal  -J {params.name}\"  --use-singularity --singularity-prefix \"$HOME/.singularity\" --singularity-args \"-B /pasteur\" " \
    if "DEMI_clocks" in folder else " --rerun-triggers mtime --keep-going --cores 12 --use-singularity --singularity-prefix ~/.singularity --singularity-args \"--home ~\""


rule all:
    input:
        expand(os.path.join(model_folder, '{model}', 'ffnn.keras'), model=MODELS),
    shell:
        """
        snakemake --snakefile Snakefile_estimate {snakemake_settings} --unlock
        snakemake --snakefile Snakefile_estimate {snakemake_settings}
        """

rule train_model_BD:
    '''
    Trains a model.
    '''
    input:
        train_trees = expand(os.path.join(sim_folder, 'BD', '{k}', 'trees.csv.xz'), k=range(N_TRAIN)),
        val_trees = expand(os.path.join(sim_folder, 'BD', '{k}', 'trees.csv.xz'), k=range(N_TRAIN,N_TOTAL)),
    output:
        model = os.path.join(model_folder, 'BD', 'ffnn.keras')
    params:
        mem=2000,
        name='tr_BD',
        qos='fast',
        path = model_folder
    threads: 1
    singularity: "docker://evolbioinfo/bdext:v0.1.37"
    shell:
        """        
        bdeissct_train --model_name BD --train_data {input.train_trees} --val_data {input.val_trees} \
        --model_path {params.path}
        """

rule train_model_BDCT:
    '''
    Trains a model.
    '''
    input:
        model = os.path.join(model_folder,'BD','ffnn.keras'),
        train_trees_nested = expand(os.path.join(sim_folder, '{model}', '{k}', 'trees.csv.xz'), k=range(N_TRAIN_OTHER), model=['BD']),
        train_trees = expand(os.path.join(sim_folder, 'BDCT', '{k}', 'trees.csv.xz'), k=range(N_TRAIN)),
        val_trees_nested = expand(os.path.join(sim_folder, '{model}', '{k}', 'trees.csv.xz'), k=range(N_TRAIN,N_TRAIN + N_VAL_OTHER), model=['BD']),
        val_trees = expand(os.path.join(sim_folder, 'BDCT', '{k}', 'trees.csv.xz'), k=range(N_TRAIN,N_TOTAL)),
    output:
        model = os.path.join(model_folder, 'BDCT', 'ffnn.keras')
    params:
        mem=2000,
        name='tr_BDCT',
        qos='fast',
        path = model_folder
    threads: 1
    singularity: "docker://evolbioinfo/bdext:v0.1.37"
    shell:
        """        
        bdeissct_train --model_name BDCT --base_model_name BD --train_data {input.train_trees_nested} {input.train_trees} \
         --val_data {input.val_trees_nested} {input.val_trees} \
        --model_path {params.path}
        """

