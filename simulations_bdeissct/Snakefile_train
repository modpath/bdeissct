rule train_model_1:
    '''
    Trains a model.
    '''
    input:
        train_trees = os.path.join(folder, f'{train}1', SIZE, '{model}', 'trees.train.csv.xz'),
        val_trees = os.path.join(folder, f'{train}1', SIZE, '{model}', 'trees.val.csv.xz'),
        # scaler = os.path.join(model_folder, 'data_scalerx_mean.npy')
    output:
        models = expand(os.path.join(folder, 'pure_models_1', SIZE, '{{model}}.keras'), p=['R', 'd'])
    params:
        mem=16000,
        name='tr_p1{model}',
        qos='fast',
        path = os.path.join(folder, 'pure_models_1', SIZE)
    threads: 1
    singularity: "docker://evolbioinfo/bdext:v0.1.80"
    shell:
        """        
        bdeissct_train --model_name {wildcards.model} --train_data {input.train_trees} --val_data {input.val_trees} \
        --model_path {params.path}
        """

