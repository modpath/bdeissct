localrules: all


folder = os.path.abspath(config.get("folder", '.'))
REPETITIONS = list(range(1000))
os.makedirs('logs', exist_ok=True)

mint = int(config.get("mint", 200))
maxt = int(config.get("maxt", 500))
SIZE = '{}_{}'.format(mint, maxt)

cf = config.get("cf", 'covid_test')
sim_folder = os.path.join(folder, config.get("sf", 'test'), SIZE)
covid_folder = os.path.join(folder, cf, SIZE)
MODELS = ['BD', 'BDCT', 'BDEI', 'BDEICT', 'BDSS', 'BDSSCT', 'BDEISS', 'BDEISSCT']


snakemake_settings = "  --rerun-triggers mtime --keep-going --cores 1 --jobs 8000 --rerun-incomplete --cluster  \"sbatch -c {threads} -o {folder}/logs/{params.name}.log -e {folder}/logs/{params.name}.log --mem={params.mem} -p common,dedicated --qos=fast  -J {params.name}\"  --use-singularity --singularity-prefix \"$HOME/.singularity\" --singularity-args \"-B /pasteur\" " \
    if "pasteur" in folder else " --rerun-triggers mtime --keep-going --cores 12 --use-singularity --singularity-prefix ~/.singularity --singularity-args \"--home ~\""

rule all:
    input:
        expand(os.path.join(covid_folder, '{model}', 'tree.{i}.nwk'), \
            i=REPETITIONS, model=MODELS)
    shell:
        """
        snakemake --snakefile Snakefile_transform_covid_train --config mint={mint} maxt={maxt} {snakemake_settings} --unlock
        snakemake --snakefile Snakefile_transform_covid_train --config mint={mint} maxt={maxt} {snakemake_settings}
        """


rule tt2phylogeny:
    '''
    Transforms a transmission tree into a phylogeny.
    '''
    input:
        nwk = os.path.join(sim_folder, '{model}', 'tree.{i}.nwk'),
        log = os.path.join(sim_folder, '{model}', 'tree.{i}.log'),
    output:
        nwk = os.path.join(covid_folder, '{model}', 'phylogeny.{i}.nwk'),
        dates = os.path.join(covid_folder, '{model}', 'dates.{i}.tab'),
        log = os.path.join(covid_folder, '{model}', 'tree.{i}.log'),
    params:
        mem=2000,
        name='tt2p',
        qos='fast',
    threads: 1
    singularity: "docker://evolbioinfo/python-evol:v3.8.2b"
    shell:
        """
        python3 py/transmission2phylogeny.py --in_nwk {input.nwk} --out_nwk {output.nwk} --out_dates {output.dates} \
        --mean_R 0.0008 --std_R 0.0004 --time_scale day --min_date 20 --max_date 30 \
        --s 29903
        
        cp {input.log} {output.log}
        """

rule date_lsd2:
    '''
    Dates a phylogeny with LSD2.
    '''
    input:
        nwk = os.path.join(covid_folder, '{model}', 'phylogeny.{i}.nwk'),
        dates = os.path.join(covid_folder, '{model}', 'dates.{i}.tab'),
    output:
        nexus = os.path.join(covid_folder, '{model}', 'tree.{i}.nexus'),
    threads: 1
    singularity: "docker://evolbioinfo/lsd2:v2.4.1"
    params:
        mem = 4000,
        name = 'lsd2',
        wd = os.path.join(covid_folder, '{model}', 'tree.{i}.wd'),
        qos = 'fast'
    shell:
        """
        # min branch length -u is set to 1 hour
        lsd2 -i {input.nwk} -d {input.dates} -s 29903 -o {params.wd} -R 24 -l 0 -u 0.0416951

        mv "{params.wd}.date.nexus" "{output.nexus}"
        rm -rf "{params.wd}*"
        """


rule nex2nwk:
    '''
    Transforms a bunch of nexus trees into a newick file.
    '''
    input:
        nexus = os.path.join(covid_folder, '{model}', 'tree.{i}.nexus'),
    output:
        nwk = os.path.join(covid_folder, '{model}', 'tree.{i}.nwk'),
    params:
        mem=2000,
        name='nex2nwk',
        qos='fast',
    threads: 1
    singularity: "docker://evolbioinfo/python-evol:v3.8.2b"
    shell:
        """
        python3 py/nex2nwk.py --in_nexus {input.nexus} --out_nwk {output.nwk}
        """

