localrules: all

folder = os.path.abspath(config.get("folder", '.'))
num = int(config.get("num",128))
REPETITIONS = list(range(num))
os.makedirs('logs',exist_ok=True)

mint = int(config.get("mint", 200))
maxt = int(config.get("maxt", 500))

sf = config.get("sf", 'train1')
mdl = config.get("model", '')
MODELS = [mdl] if mdl else [f'BD{ei}{ss}{ct}' for ei in ['', 'EI'] for ss in ['', 'SS'] for ct in ['', 'CT']]
model_arg = f" model={mdl} " if mdl else ""


snakemake_settings = "  --rerun-triggers mtime --keep-going --cores 1 --jobs 500 --rerun-incomplete --cluster  \"sbatch -c {threads} -o {folder}/logs/{params.name}.log -e {folder}/logs/{params.name}.log --mem={params.mem} -p common,dedicated --qos=fast  -J {params.name}\"  --use-singularity --singularity-prefix \"$HOME/.singularity\" --singularity-args \"-B /pasteur\" " \
    if "pasteur" in folder else " --rerun-triggers mtime --keep-going --cores 12 --use-singularity --singularity-prefix ~/.singularity --singularity-args \"--home ~\""

rule all:
    input:
        expand(os.path.join(folder, f'covid_{sf}', f'{mint}_{maxt}', '{model}', 'trees.{i}.nwk'), i=REPETITIONS,model=MODELS),
    shell:
        """
        snakemake --snakefile Snakefile_encode --config mint={mint} maxt={maxt} {model_arg} sf=covid_{sf} {snakemake_settings} --unlock
        snakemake --snakefile Snakefile_encode --config mint={mint} maxt={maxt} {model_arg} sf=covid_{sf} {snakemake_settings} --rerun-incomplete
        """


rule tt2covid:
    '''
    Transforms a transmission tree into a LSD2-dated COVID phylogeny.
    '''
    input:
        nwk=os.path.join(folder, '{train}', f'{mint}_{maxt}', '{model}', 'trees.{i}.nwk'),
        log=os.path.join(folder, '{train}', f'{mint}_{maxt}', '{model}', 'trees.{i}.log')
    output:
        nwk=os.path.join(folder, 'covid_{train}', f'{mint}_{maxt}', '{model}', 'trees.{i}.nwk'),
        log=os.path.join(folder, 'covid_{train}', f'{mint}_{maxt}', '{model}', 'trees.{i}.log')
    params:
        mem=1000,
        name='tt2ctt',
        qos='normal',
    threads: 1
    shell:
        """
        mkdir -p {input.nwk}.phylogenies
        source ~/.bashrc && conda activate snakemake && module load apptainer && cd {input.nwk}.phylogenies
        
        snakemake --snakefile {folder}/Snakefile_transform_covid --config in_nwk={input.nwk} out_nwk={output.nwk} folder={folder} {snakemake_settings} --unlock
        snakemake --snakefile {folder}/Snakefile_transform_covid --config in_nwk={input.nwk} out_nwk={output.nwk} folder={folder} {snakemake_settings}
        
        cp {input.log} {output.log}
        rm -rf {input.nwk}.phylogenies
        """
