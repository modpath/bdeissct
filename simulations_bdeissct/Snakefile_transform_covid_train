localrules: all

folder = os.path.abspath(config.get("folder", '.'))
num = int(config.get("num",128))
REPETITIONS = list(range(num))
os.makedirs('logs',exist_ok=True)

mint = int(config.get("mint", 200))
maxt = int(config.get("maxt", 500))
SIZE = '{}_{}'.format(mint, maxt)

cf = config.get("cf",'covid_train')
sim_folder = os.path.join(folder,config.get("sf",'train'), SIZE)
covid_folder = os.path.join(folder,cf, SIZE)
MODELS = ['BD', 'BDCT', 'BDEI', 'BDEICT', 'BDSS', 'BDSSCT', 'BDEISS', 'BDEISSCT']

TREES_PER_FILE = 8

snakemake_settings = "  --rerun-triggers mtime --keep-going --cores 1 --jobs 500 --rerun-incomplete --cluster  \"sbatch -c {threads} -o {folder}/logs/{params.name}.log -e {folder}/logs/{params.name}.log --mem={params.mem} -p common --qos={params.qos}  -J {params.name}\"  --use-singularity --singularity-prefix \"$HOME/.singularity\" --singularity-args \"-B /pasteur\" " \
    if "pasteur" in folder else " --rerun-triggers mtime --keep-going --cores 12 --use-singularity --singularity-prefix ~/.singularity --singularity-args \"--home ~\""

rule all:
    input:
        expand(os.path.join(covid_folder,'{model}','{k}','trees.{i}.nwk'), \
            k=REPETITIONS,i=REPETITIONS,model=MODELS),
        expand(os.path.join(covid_folder,'{model}','{k}','trees.{i}.log'), \
            k=REPETITIONS,i=REPETITIONS,model=MODELS)
    shell:
        """
        snakemake --snakefile Snakefile_encode --config mint={mint} maxt={maxt} sf={cf} {snakemake_settings} --unlock
        snakemake --snakefile Snakefile_encode --config mint={mint} maxt={maxt} sf={cf} {snakemake_settings} --rerun-incomplete
        """


rule tt2covid:
    '''
    Transforms a transmission tree into a LSD2-dated COVID phylogeny.
    '''
    input:
        nwk=os.path.join(sim_folder,'{model}','{k}','trees.{i}.nwk')
    output:
        nwk=os.path.join(covid_folder,'{model}','{k}','trees.{i}.nwk')
    params:
        mem=1000,
        name='tt2ctt',
        qos='fast',
        tt=os.path.join(sim_folder,'{model}','{k}'),
        ct=os.path.join(covid_folder,'{model}','{k}'),
    threads: 1
    shell:
        """
        mkdir -p {params.tt}/{wildcards.i}
        source ~/.bashrc && conda activate snakemake && module load apptainer && cd {params.tt}/{wildcards.i}
        
        snakemake --snakefile {folder}/Snakefile_transform_covid --config tt={params.tt} covid={params.ct} folder={folder} i={wildcards.i} {snakemake_settings} --unlock
        snakemake --snakefile {folder}/Snakefile_transform_covid --config tt={params.tt} covid={params.ct} folder={folder} i={wildcards.i} {snakemake_settings}
        
        cd {folder}
        rm -rf {params.tt}/{wildcards.i}
        """

rule copy_logs:
    '''
    Copies log files to the covid folder.
    '''
    input:
        log = expand(os.path.join(sim_folder, '{{model}}', '{{k}}', 'trees.{i}.log'), i=REPETITIONS)
    output:
        log = expand(os.path.join(covid_folder, '{{model}}', '{{k}}', 'trees.{i}.log'), i=REPETITIONS)
    params:
        mem=1000,
        name='cp_logs',
        qos='fast',
        pattern=os.path.join(sim_folder,'{model}', '{k}', 'trees.*.log'),
        ct=os.path.join(covid_folder,'{model}', '{k}'),
    threads: 1
    shell:
        """
        cp {params.pattern} {params.ct}
        """
