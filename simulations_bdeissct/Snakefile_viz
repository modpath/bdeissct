localrules: all
ruleorder: combine_estimates > combine_dl_estimates

os.makedirs('logs', exist_ok=True)


folder = config.get("folder", '.')
sim_folder = config.get("sf", 'test')
n = int(config.get("num", 100))
REPETITIONS = list(range(n))
M = int(config.get('max', 1000))
MODELS = ['BDCT0', 'BDCT1', 'BDCT2', f'BDCT{M}'] \
         + ['BDEICT0', 'BDEICT1', 'BDEICT2', f'BDEICT{M}'] \
         + ['BDSSCT0', 'BDSSCT1', 'BDSSCT2', f'BDSSCT{M}']
# DATA_TYPES = ['forest', 'tree']
DATA_TYPES = ['tree']


rule all:
    input:
        # expand(os.path.join(sim_folder, '{model}', 'errors.svg'), model=MODELS),
        # expand(os.path.join(sim_folder, '{model}', 'error_bars.svg'), model=MODELS),
        # os.path.join(sim_folder, 'error_bars.svg'),
        # expand(os.path.join(sim_folder, '{model}', 'errors_trees.svg'), model=MODELS),
        expand(os.path.join(sim_folder, '{model}_error_bars.svg'), model=['BD', 'BDEI', 'BDSS']),
        expand(os.path.join(sim_folder, '{model}', 'CI_stats.txt'), model=MODELS),


rule CI_stats:
    '''
    Calculate CI stats for estimated parameters.
    '''
    input:
        tab = os.path.join(sim_folder, '{model}', 'estimates.tab'),
    output:
        stats = os.path.join(sim_folder, '{model}', 'CI_stats.txt'),
    params:
        mem = 2000,
        name = 'CIs',
        qos = 'fast',
    threads: 1
    singularity: "docker://evolbioinfo/python-evol:v3.6richer.2"
    shell:
        """
        python3 py/assess_CIs.py --estimates {input.tab} --log {output.stats} --model {wildcards.model}
        """

rule combine_estimates:
    '''
    Combine estimates.
    '''
    input:
        log = expand(os.path.join(sim_folder, '{{model}}', '{type}.{i}.log'), i=REPETITIONS, type=DATA_TYPES),
        est_bd = expand(os.path.join(sim_folder, '{{model}}', '{type}.{i}.est_bd'), i=REPETITIONS, type=DATA_TYPES),
        est_bdct = expand(os.path.join(sim_folder, '{{model}}', '{type}.{i}.est_bdct'), i=REPETITIONS, type=DATA_TYPES),
        est_bddl = expand(os.path.join(sim_folder, '{{model}}', '{type}.estimates_BD.csv.xz'), type=DATA_TYPES),
        est_bdct1dl = expand(os.path.join(sim_folder, '{{model}}', '{type}.estimates_BDCT1.csv.xz'), type=DATA_TYPES),
        est_bdct2dl = expand(os.path.join(sim_folder, '{{model}}', '{type}.estimates_BDCT2.csv.xz'), type=DATA_TYPES),
        est_bdct2000dl = expand(os.path.join(sim_folder, '{{model}}', '{type}.estimates_BDCT2000.csv.xz'), type=DATA_TYPES),
        est_bdeidl = expand(os.path.join(sim_folder, '{{model}}', '{type}.estimates_BDEI.csv.xz'), type=DATA_TYPES),
        est_bdeict1dl = expand(os.path.join(sim_folder, '{{model}}', '{type}.estimates_BDEICT1.csv.xz'), type=DATA_TYPES),
        est_bdeict2dl = expand(os.path.join(sim_folder, '{{model}}', '{type}.estimates_BDEICT2.csv.xz'), type=DATA_TYPES),
        est_bdeict2000dl = expand(os.path.join(sim_folder, '{{model}}', '{type}.estimates_BDEICT2000.csv.xz'), type=DATA_TYPES),
        est_bdssdl = expand(os.path.join(sim_folder, '{{model}}', '{type}.estimates_BDSS.csv.xz'), type=DATA_TYPES),
        est_bdssct1dl = expand(os.path.join(sim_folder, '{{model}}', '{type}.estimates_BDSSCT1.csv.xz'), type=DATA_TYPES),
        est_bdssct2dl = expand(os.path.join(sim_folder, '{{model}}', '{type}.estimates_BDSSCT2.csv.xz'), type=DATA_TYPES),
        est_bdssct2000dl = expand(os.path.join(sim_folder, '{{model}}', '{type}.estimates_BDSSCT2000.csv.xz'), type=DATA_TYPES),
        est_mfdl = expand(os.path.join(sim_folder, '{{model}}', '{type}.estimates_MF.csv.xz'), type=DATA_TYPES),
    output:
        tab = os.path.join(sim_folder, '{model}', 'estimates.tab'),
    params:
        mem = 2000,
        name = 'estimates',
        qos = 'fast',
    threads: 1
    singularity: "docker://evolbioinfo/python-evol:v3.6richer.2"
    shell:
        """
        python3 py/summary_table.py --real {input.log} \
        --estimates_bd {input.est_bd} \
        --estimates_bdct {input.est_bdct} \
        --estimates_bddl {input.est_bddl} \
        --estimates_bdct1dl {input.est_bdct1dl} \
        --estimates_bdct2dl {input.est_bdct2dl} \
        --estimates_bdct2000dl {input.est_bdct2000dl} \
        --estimates_bdeidl {input.est_bdeidl} \
        --estimates_bdeict1dl {input.est_bdeict1dl} \
        --estimates_bdeict2dl {input.est_bdeict2dl} \
        --estimates_bdeict2000dl {input.est_bdeict2000dl} \
        --estimates_bdssdl {input.est_bdssdl} \
        --estimates_bdssct1dl {input.est_bdssct1dl} \
        --estimates_bdssct2dl {input.est_bdssct2dl} \
        --estimates_bdssct2000dl {input.est_bdssct2000dl} \
        --estimates_mfdl {input.est_mfdl} \
        --tab {output.tab}
        """


