rule plot_errors:
    '''
    Plots the errors.
    '''
    input:
        tab = os.path.join(sim_folder, '{model}', 'estimates.tab'),
    output:
        pdf = os.path.join(sim_folder, '{model}', 'errors.svg'),
        tab = os.path.join(sim_folder, '{model}', 'errors.tab'),
    params:
        mem = 2000,
        name = 'errors',
        qos = 'fast'
    threads: 1
    singularity: "docker://evolbioinfo/python-evol:v3.6richer.2"
    shell:
        """
        echo "python3 py/plot_error.py --estimates {input.tab} --tab {output.tab} --pdf {output.pdf}"
        python3 py/plot_error.py --estimates {input.tab} --tab {output.tab} --pdf {output.pdf} 
        """

rule plot_error_bars:
    '''
    Plots the errors.
    '''
    input:
        tab = os.path.join(sim_folder, '{model}', 'estimates.tab'),
    output:
        pdf = os.path.join(sim_folder, '{model,(BDSS|BDEI|BD)CT[0-9]+}', 'error_bars.svg'),
    params:
        mem = 2000,
        name = 'errors',
        qos = 'fast'
    threads: 1
    singularity: "docker://evolbioinfo/python-evol:v3.6richer.2"
    shell:
        """
        python3 py/plot_error_bars.py --estimates {input.tab}  --pdf {output.pdf}  --only_trees
        """

rule plot_error_bars_model:
    '''
    Plots the errors.
    '''
    input:
        tab0 = os.path.join(sim_folder, '{model}CT0', 'estimates.tab'),
        tab1 = os.path.join(sim_folder, '{model}CT1', 'estimates.tab'),
        tab2 = os.path.join(sim_folder, '{model}CT2', 'estimates.tab'),
        tab1000 = os.path.join(sim_folder, '{model}CT1000', 'estimates.tab'),
    output:
        pdf = os.path.join(sim_folder, '{model,BDSS|BDEI|BD}_error_bars.svg'),
    params:
        mem = 2000,
        name = 'errors',
        qos = 'fast'
    threads: 1
    singularity: "docker://evolbioinfo/python-evol:v3.6richer.2"
    shell:
        """
        python3 py/plot_error_bars_all.py --estimates {input.tab0} {input.tab1} {input.tab2} {input.tab1000}  --pdf {output.pdf}  --only_trees
        """

rule plot_error_bars_all:
    '''
    Plots the errors.
    '''
    input:
        tab = expand(os.path.join(sim_folder, '{model}', 'estimates.tab'), model=MODELS),
    output:
        pdf = os.path.join(sim_folder, 'error_bars.svg'),
    params:
        mem = 2000,
        name = 'errors',
        qos = 'fast'
    threads: 1
    singularity: "docker://evolbioinfo/python-evol:v3.6richer.2"
    shell:
        """
        python3 py/plot_error_bars_all.py --estimates {input.tab} --pdf {output.pdf} --only_trees
        """

rule plot_errors_trees:
